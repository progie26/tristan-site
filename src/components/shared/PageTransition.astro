<!-- ============================================================
   PageTransition.astro — View Transition wrapper
   Uses Astro's built-in ViewTransitions + CSS for morphing.
   ============================================================ -->

---
import { ViewTransitions } from "astro:transitions";
---

<ViewTransitions />

<style is:global>
  /* ---- View Transition Defaults ---- */
  @view-transition {
    navigation: auto;
  }

  /* Old page: fade out + slide up slightly */
  ::view-transition-old(root) {
    animation: vt-exit var(--duration-normal) var(--ease-in) both;
  }

  /* New page: fade in + slide down from slight offset */
  ::view-transition-new(root) {
    animation: vt-enter var(--duration-slow) var(--ease-out) both;
  }

  @keyframes vt-exit {
    to {
      opacity: 0;
      transform: translateY(-4px);
    }
  }

  @keyframes vt-enter {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Reduced motion: simple crossfade */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none;
    }
    ::view-transition-old(root) {
      opacity: 0;
    }
    ::view-transition-new(root) {
      opacity: 1;
    }
  }
</style>
