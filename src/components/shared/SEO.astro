<!-- ============================================================
   SEO.astro — OG / Twitter card meta tags
   ============================================================ -->

---
interface Props {
  title: string;
  description: string;
  ogImage: string;
  canonicalURL: string;
}

const { title, description, ogImage, canonicalURL } = Astro.props;
const siteUrl = Astro.site?.href ?? "https://tristanchen.me";
---

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(ogImage, siteUrl).href} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content="Tristan Chen" />
<meta property="og:locale" content="zh_CN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, siteUrl).href} />

<!-- Schema.org -->
<script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Tristan Chen",
    "url": "{{ siteUrl }}",
    "description": "{{ description }}"
  }
</script>
