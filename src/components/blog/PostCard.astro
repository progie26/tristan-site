<!-- ============================================================
   PostCard.astro — Blog post preview card
   Used in list pages and Bento grid. Shows cover / title / date / tags.
   ============================================================ -->

---
import Card from "../ui/Card.astro";
import Tag from "../ui/Tag.astro";
import { formatDate } from "../../lib/utils";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  /** Bento grid size — for homepage usage */
  size?: "1x1" | "2x1" | "1x2" | "2x2";
  /** Show excerpt on hover — used in Bento grid */
  peek?: boolean;
  class?: string;
}

const { post, size = "1x1", peek = false, class: className } = Astro.props;
const { title, description, date, tags, image, lang } = post.data;
const href = `/writing/${post.slug}`;
---

<Card size={size} href={href} expandable class={className}>
  <article class="post-card">
    {image && (
      <div class="post-card-image">
        <img src={image} alt={title} loading="lazy" decoding="async" />
      </div>
    )}

    <div class="post-card-body">
      <h3 class="post-card-title" lang={lang}>
        {title}
      </h3>

      {peek && (
        <p class="post-card-desc">{description}</p>
      )}

      <div class="post-card-meta">
        <time datetime={date.toISOString()} class="post-card-date">
          {formatDate(date)}
        </time>

        {tags.length > 0 && (
          <div class="post-card-tags">
            {tags.slice(0, 3).map((tag) => (
              <Tag label={tag} size="sm" />
            ))}
          </div>
        )}
      </div>
    </div>
  </article>
</Card>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
  }

  .post-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 8px;
    background: var(--color-bg-inset);
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .card:hover .post-card-image img {
    transform: scale(1.03);
  }

  .post-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .post-card-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    margin: 0;
    color: var(--color-ink);
  }

  .post-card-desc {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-ink-secondary);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-block-start: auto;
  }

  .post-card-date {
    font-size: var(--text-xs);
    color: var(--color-ink-tertiary);
    white-space: nowrap;
  }

  .post-card-tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
    justify-content: flex-end;
  }
</style>
