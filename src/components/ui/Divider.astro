<!-- ============================================================
   Divider.astro — Horizontal or vertical divider
   Optional label text
   ============================================================ -->

---
interface Props {
  /** "horizontal" (default) or "vertical" */
  direction?: "horizontal" | "vertical";
  label?: string;
  class?: string;
}

const { direction = "horizontal", label, class: className } = Astro.props;
---

{
  label ? (
    <div
      class={["divider-with-label", `divider--${direction}`, className]
        .filter(Boolean)
        .join(" ")}
    >
      <span class="divider-line" />
      <span class="divider-label">{label}</span>
      <span class="divider-line" />
    </div>
  ) : (
    <hr
      class={["divider", `divider--${direction}`, className]
        .filter(Boolean)
        .join(" ")}
    />
  )
}

<style>
  .divider {
    border: none;
    margin: 0;
  }

  .divider--horizontal {
    width: 100%;
    height: 1px;
    background: var(--color-border);
    margin-block: var(--space-4);
  }

  .divider--vertical {
    width: 1px;
    height: 100%;
    background: var(--color-border);
    margin-inline: var(--space-4);
  }

  /* With label */
  .divider-with-label {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .divider-with-label.divider--horizontal {
    width: 100%;
    margin-block: var(--space-4);
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .divider-label {
    font-size: var(--text-xs);
    color: var(--color-ink-tertiary);
    white-space: nowrap;
    font-weight: var(--weight-medium);
  }
</style>
