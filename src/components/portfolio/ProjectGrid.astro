<!-- ============================================================
   ProjectGrid.astro — Project card grid container
   Desktop: 2 columns, Mobile: 1 column
   ============================================================ -->

---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={["project-grid", className].filter(Boolean).join(" ")}>
  <slot />
</div>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .project-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .project-grid {
      gap: var(--space-8);
    }
  }
</style>
