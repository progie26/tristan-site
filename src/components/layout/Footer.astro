<!-- ============================================================
   Footer.astro — Simple page footer
   ============================================================ -->

---
import { COPYRIGHT, SOCIAL_LINKS } from "../../lib/constants";
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-links">
      <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <span aria-hidden="true">·</span>
      <a href={`mailto:${SOCIAL_LINKS.email}`}>Email</a>
      <span aria-hidden="true">·</span>
      <a href={SOCIAL_LINKS.rss}>RSS</a>
    </div>
    <p class="footer-copy">{COPYRIGHT}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-10);
    margin-block-start: var(--space-16);
  }

  .footer-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--page-padding-x);
    text-align: center;
  }

  .footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-ink-secondary);
  }

  .footer-links a {
    color: var(--color-ink-secondary);
  }
  .footer-links a:hover {
    color: var(--color-ink);
  }

  .footer-copy {
    margin-block-start: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-ink-tertiary);
  }
</style>
