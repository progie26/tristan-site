<!-- ============================================================
   index.astro — Homepage: BentoDashboard
   12-column CSS Grid filling the viewport.
   No scroll — all content visible in one screen.
   ============================================================ -->

---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/ui/Card.astro";
import Tag from "../components/ui/Tag.astro";
import HeroPanel from "../components/home/HeroPanel.astro";
import ArticlePreviewCard from "../components/home/ArticlePreviewCard.astro";
import ProjectPreviewCard from "../components/home/ProjectPreviewCard.astro";
import FilterPills from "../components/interactive/FilterPills.tsx";
import { SITE } from "../lib/constants";
import { formatDate } from "../lib/utils";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const recentPosts = sortedPosts.slice(0, 3);

const allProjects = await getCollection("projects", ({ data }) => !data.draft);
const sortedProjects = allProjects.sort(
  (a, b) => (b.data.year ?? 0) - (a.data.year ?? 0)
);
const featuredProjects = sortedProjects.filter((p) => p.data.featured).slice(0, 2);

// Collect all unique tags
const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
for (const project of allProjects) {
  for (const tag of project.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const allTags = [...tagMap.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([slug, count]) => ({ slug, labelZh: slug, labelEn: `${count}`, color: "var(--color-accent)" }));
---

<BaseLayout
  title={SITE.title}
  description={SITE.description}
  canonicalURL={Astro.site?.href ?? "https://tristanchen.me"}
  currentPath="/"
  hideFooter
>
  <div class="home">
    <div class="bento-grid">
      <!-- Hero — largest card -->
      <HeroPanel blogCount={allPosts.length} projectCount={allProjects.length} />

      <!-- Tag Cloud -->
      <Card size="1x1" class="tag-cloud-card">
        <h2 class="home-section-label">标签</h2>
        <div class="tag-cloud">
          {allTags.map((tag) => (
            <a href={`/tags/${tag.slug}`} class="tag-cloud-link">
              <Tag label={tag.slug} size="sm" />
            </a>
          ))}
        </div>
      </Card>

      <!-- Recent Posts section -->
      <Card size="1x1" class="recent-posts-card">
        <h2 class="home-section-label">
          <a href="/writing" class="section-link">最近文章 →</a>
        </h2>
        <ul class="recent-posts-list">
          {recentPosts.map((post) => (
            <li>
              <a href={`/writing/${post.slug}`} class="recent-post-link">
                <span class="recent-post-title">{post.data.title}</span>
                <span class="recent-post-date">{formatDate(post.data.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      </Card>

      <!-- Featured projects -->
      {featuredProjects.map((project) => (
        <ProjectPreviewCard project={project} />
      ))}

      <!-- Remaining article preview cards -->
      {recentPosts.slice(0, 2).map((post) => (
        <ArticlePreviewCard post={post} />
      ))}

      <!-- Mini cards — contact & links -->
      <Card size="1x1" class="mini-card">
        <a href="/about" class="mini-card-link">
          <span class="mini-card-icon">👤</span>
          <span class="mini-card-label">关于我</span>
        </a>
      </Card>

      <Card size="1x1" class="mini-card">
        <a href="https://github.com/tristanchen" target="_blank" rel="noopener noreferrer" class="mini-card-link">
          <span class="mini-card-icon">⬢</span>
          <span class="mini-card-label">GitHub</span>
        </a>
      </Card>
    </div>
  </div>
</BaseLayout>

<style>
  /* ---- Homepage: fill viewport, no scroll ---- */
  .home {
    height: calc(100dvh - 48px); /* 48px = header height */
    overflow: hidden;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 1fr;
    gap: var(--space-4);
    padding: var(--space-4);
    max-width: var(--grid-max);
    margin: 0 auto;
    height: 100%;
    /* 4 rows of equal height */
    grid-template-rows: repeat(4, 1fr);
  }

  /* ---- Section labels ---- */
  .home-section-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-ink-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--space-2);
  }

  .section-link {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ink-tertiary);
  }

  /* ---- Tag cloud ---- */
  .tag-cloud-card {
    overflow-y: auto;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .tag-cloud-link {
    background-image: none;
    display: inline-flex;
  }
  .tag-cloud-link:hover {
    background-image: none;
    transform: scale(1.05);
    transition: transform var(--duration-fast);
  }

  /* ---- Recent posts mini list ---- */
  .recent-posts-card {
    overflow-y: auto;
  }

  .recent-posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .recent-post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-2);
    border-radius: 6px;
    background-image: none;
    color: var(--color-ink);
    font-size: var(--text-sm);
    transition: background-color var(--duration-fast);
  }
  .recent-post-link:hover {
    background-color: var(--color-bg-inset);
    background-image: none;
  }

  .recent-post-title {
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .recent-post-date {
    font-size: var(--text-xs);
    color: var(--color-ink-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ---- Mini cards ---- */
  .mini-card {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mini-card-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    background-image: none;
    color: var(--color-ink-secondary);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    text-align: center;
    padding: var(--space-4);
  }
  .mini-card-link:hover {
    color: var(--color-accent);
    background-image: none;
  }

  .mini-card-icon {
    font-size: var(--text-2xl);
  }

  /* ---- Responsive ---- */
  @media (max-width: 1023px) {
    .bento-grid {
      grid-template-columns: repeat(8, 1fr);
      grid-template-rows: auto;
      grid-auto-rows: auto;
      gap: var(--space-3);
      padding: var(--space-3);
    }

    .home {
      height: auto;
      overflow: visible;
    }
  }

  @media (max-width: 767px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      padding: var(--space-3);
      grid-template-rows: auto;
    }

    .home {
      height: auto;
      overflow: visible;
    }
  }
</style>
